@model ProductCreateVM

@{
    ViewData["Title"] = "Edit Product";
    Layout = "_LayoutAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Edit Product</h3>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Product.Id" />
    <input type="hidden" asp-for="Product.CreatedAt" />

    <div class="row">
        <div class="col-md-6 mb-3">
            <label>Category</label>
            <select asp-for="Product.CategoryId" asp-items="Model.Categories" class="form-control">
                <option value="">-- Select Category --</option>
            </select>
            <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label>Name</label>
            <input asp-for="Product.Name" class="form-control" />
            <span asp-validation-for="Product.Name" class="text-danger"></span>
        </div>

        <div class="col-md-12 mb-3">
            <label>Description</label>
            <textarea asp-for="Product.Description" class="form-control" rows="4"></textarea>
        </div>

        <div class="col-md-3 mb-3">
            <label>Price</label>
            <input asp-for="Product.Price" class="form-control" />
        </div>

        <div class="col-md-3 mb-3">
            <label>Stock</label>
            <input asp-for="Product.Stock" class="form-control" />
        </div>

        <div class="col-md-3 mb-3">
            <label>Reorder Level</label>
            <input asp-for="Product.ReorderLevel" class="form-control" />
        </div>

        <div class="col-md-3 mb-3">
            <label>
                <input asp-for="Product.IsActive" /> Active
            </label>
        </div>

        <div class="col-md-12 mb-3">
            <label>Product Image (300px x 300px)</label>
            <div class="mb-2">
                @if (!string.IsNullOrEmpty(Model.Product.ImageUrl))
                {
                    <div>
                        <p class="text-muted">Current Image:</p>
                        <img src="/images/Products/@Model.Product.ImageUrl" alt="Product Image" style="max-width: 200px; max-height: 200px; border-radius: 5px;" class="mb-2" />
                    </div>
                }
            </div>
            <input asp-for="Product.Image" class="form-control" type="file" accept="image/*" />
            <small class="text-muted">Leave empty to keep current image</small>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">Update Product</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </div>
</form>


