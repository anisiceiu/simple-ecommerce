@using ECommerce.Domain
@model Category
@{
    ViewData["Title"] = "Edit Category";
    Layout = "_LayoutAdmin";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Edit Category</h2>
</div>

<div class="card shadow mb-4">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="CreatedAt" />

            <div class="mb-3">
                <label class="form-label">Category Name</label>
                <input asp-for="Name" class="form-control" placeholder="Enter category name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="IsActive" class="form-check-input" id="isActiveCheck" />
                <label class="form-check-label" for="isActiveCheck">Active</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary mr-2">
                    <i class="fas fa-save"></i> Update Category
                </button>
                <button asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </button>
            </div>
        </form>
    </div>
</div>

