@using ecommerce.Models
@model ProductDetailsVM
<!-- content-wraper start -->
<div class="content-wraper">
    <div class="container">
        <div class="row single-product-area">
            <div class="col-lg-5 col-md-6">
                <!-- Product Details Left -->
                <div class="product-details-left">
                    <div class="product-details-images slider-navigation-1">
                        <div class="product-image" style="height:100%">
                            <a href="/Home/ProductDetails?id=@Model.Product.Id">
                                <img onerror="this.onerror=null;this.src='/images/products/no-image.png';" src="/images/products/@Model.Product.ImageUrl" alt="Li's Product Image">
                            </a>
                        </div>

                    </div>
                    <!--// Product Details Left -->
                </div>
            </div>
            <div class="col-lg-7 col-md-6">
                <div class="product-details-view-content pt-60">
                    <div class="product-info">
                        <h2>@Model.Product.Name</h2>
                        <div class="rating-wrapper"
                             data-product-id="@Model.Product.Id"
                             data-user-rating="@Model.UserRating"
                             data-average-rating="@Model.AverageRating">

                            <ul class="star-rating user-rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <li data-value="@i" class="@(i <= Model.UserRating ? "active" : "")">&#9733;</li>
                                }
                            </ul>

                            <div class="avg-rating">
                                Average Rating:
                                <span>@Model.AverageRating.ToString("0.0")</span> / 5 
                                <span class="rating-count">(@Model.TotalRatings reviews)</span>
                            </div>
                        </div>

                        <!-- Rating Distribution -->
                        @if (Model.TotalRatings > 0)
                        {
                            <div class="rating-distribution mt-3 mb-3">
                                @for (int stars = 5; stars >= 1; stars--)
                                {
                                    int count = Model.RatingDistribution.ContainsKey(stars) ? Model.RatingDistribution[stars] : 0;
                                    double percentage = Model.TotalRatings > 0 ? (count * 100.0 / Model.TotalRatings) : 0;
                                    <div class="rating-bar-item mb-2">
                                        <span class="stars-label">@stars ★</span>
                                        <div class="rating-bar-container">
                                            <div class="rating-bar-fill" style="width: @percentage%"></div>
                                        </div>
                                        <span class="rating-count">(@count)</span>
                                    </div>
                                }
                            </div>
                        }

                        <div class="price-box pt-20">
                            <span class="new-price new-price-2">$@Model.Product.Price</span>
                        </div>
                        <div class="product-desc">
                            <p>
                                <span>
                                    @Model.Product.Description
                                </span>
                            </p>
                        </div>

                        <div class="single-add-to-cart">
                            <div class="cart-quantity" style="margin-bottom:10px;">
                                <button style="cursor:pointer" class="add-to-cart" data-id="@Model.Product.Id" data-name="@Model.Product.Name" data-price="@Model.Product.Price">Add to cart</button>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <!-- Reviews Section -->
        <div class="row mt-5">
            <div class="col-lg-12">
                <div class="reviews-section">
                    <h3 class="reviews-title mb-4">Customer Reviews (@Model.TotalRatings)</h3>

                    @if (Model.Reviews.Any())
                    {
                        <div class="reviews-list">
                            @foreach (var review in Model.Reviews)
                            {
                                <div class="review-item mb-4 p-3 border rounded">
                                    <div class="review-header d-flex justify-content-between align-items-start">
                                        <div class="review-user-info">
                                            <h5 class="review-user-name">@review.UserDisplayName</h5>
                                            <div class="review-rating mb-2">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <span class="star" style="color: @(i <= review.Rating ? "#ffc107" : "#ccc")">★</span>
                                                }
                                                <span class="ml-2 text-muted">@review.Rating.0 / 5</span>
                                            </div>
                                            <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy HH:mm")</small>
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(review.Comment))
                                    {
                                        <div class="review-comment mt-2">
                                            <p>@review.Comment</p>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No reviews yet. Be the first to review this product!</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!-- content-wraper end -->

<style>
    .rating-distribution {
        background: #f8f9fa;
        padding: 15px;
        border-radius: 5px;
    }

    .rating-bar-item {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .stars-label {
        min-width: 40px;
        font-weight: bold;
    }

    .rating-bar-container {
        flex: 1;
        height: 8px;
        background: #e9ecef;
        border-radius: 4px;
        overflow: hidden;
    }

    .rating-bar-fill {
        height: 100%;
        background: #ffc107;
        transition: width 0.3s ease;
    }

    .rating-count {
        min-width: 50px;
        text-align: right;
        font-size: 0.9em;
        color: #666;
    }

    .reviews-section {
        background: #f8f9fa;
        padding: 30px;
        border-radius: 8px;
    }

    .reviews-title {
        color: #333;
        font-weight: bold;
        border-bottom: 2px solid #007bff;
        padding-bottom: 10px;
    }

    .review-item {
        background: white;
        border: 1px solid #dee2e6;
    }

    .review-user-name {
        font-weight: bold;
        color: #333;
        margin-bottom: 5px;
    }

    .review-rating {
        color: #ffc107;
        font-size: 1.1em;
    }

    .star {
        margin-right: 2px;
    }

    .review-comment {
        color: #555;
        line-height: 1.6;
    }

    .user-rating li {
        cursor: pointer;
        font-size: 1.8em;
        margin-right: 5px;
        color: #ccc;
        transition: color 0.2s;
    }

    .user-rating li.selected {
        color: #ffc107;
    }

    .user-rating li.hover {
        color: #ffc107;
    }

    .user-rating li.avg {
        color: #ccc;
        position: relative;
    }
</style>

<script>


    $(document).ready(function () {

        function fillStars(container, rating, className) {
            container.find('li').each(function () {
                let value = $(this).data('value');
                $(this).toggleClass(className, value <= rating);
            });
        }

        $('.rating-wrapper').each(function () {
            let wrapper = $(this);
            let userRating = wrapper.data('user-rating');
            let avgRating = wrapper.data('average-rating');

            fillStars(wrapper.find('.user-rating'), userRating, 'selected');
            fillStars(wrapper.find('.user-rating'), avgRating, 'avg');
        });

        $('.user-rating li').hover(
            function () {
                let rating = $(this).data('value');
                fillStars($(this).parent(), rating, 'hover');
            },
            function () {
                $(this).parent().find('li').removeClass('hover');
            }
        );

        $('.user-rating li').click(function () {
            let rating = $(this).data('value');
            let wrapper = $(this).closest('.rating-wrapper');
            let productId = wrapper.data('product-id');

            $.post('/Home/Rate', {
                productId: productId,
                rating: rating
            }).done(function () {
                location.reload();
            });
        });
    });
</script>
