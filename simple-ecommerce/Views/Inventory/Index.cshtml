@model IEnumerable<ecommerce.Models.ProductViewModel>

@{
    ViewData["Title"] = "Inventory";
    Layout = "_LayoutAdmin";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Inventory</h3>

        
    </div>

    @* <form method="get" class="row g-2 mb-3">

        <div class="col-md-4">
            <input type="text"
                   name="search"
                   value="@Context.Request.Query["search"]"
                   class="form-control"
                   placeholder="Search product..." />
        </div>

        <div class="col-md-2">
            <button class="btn btn-primary w-100">
                Search
            </button>
        </div>

    </form> *@

    <div class="card shadow-sm">

        <div class="card-header">
            Current Stock
        </div>

        <div class="card-body p-0">

            <table class="table table-hover table-bordered mb-0">

                <thead class="table-light">

                    <tr>
                        <th>ID</th>
                        <th>Product</th>
                        <th>Category</th>
                        <th class="text-end">Price</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center">Reorder</th>
                        <th>Status</th>
                        <th width="180">Action</th>
                    </tr>

                </thead>

                <tbody>

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4">
                                No products found.
                            </td>
                        </tr>
                    }

                    @foreach (var item in Model)
                    {
                        var badge = "bg-success";
                        var text = "In Stock";

                        if (item.Stock <= 0)
                        {
                            badge = "bg-danger";
                            text = "Out of Stock";
                        }
                        else if (item.Stock <= item.ReorderLevel)
                        {
                            badge = "bg-warning";
                            text = "Low Stock";
                        }

                        <tr>

                            <td>@item.Id</td>

                            <td>@item.Name</td>

                            <td>@item.Category.Name</td>

                            <td class="text-end">
                                @item.Price.ToString("0.00")
                            </td>

                            <td class="text-center">
                                @item.Stock
                            </td>

                            <td class="text-center">
                                @item.ReorderLevel
                            </td>

                            <td>
                                <span class="badge @badge">
                                    @text
                                </span>
                            </td>

                            <td>

                                <a asp-controller="InventoryOperations"
                                   asp-action="StockIn"
                                   asp-route-id="@item.Id"
                                   class="btn btn-success btn-sm">
                                    In
                                </a>

                                <a asp-controller="InventoryOperations"
                                   asp-action="StockOut"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">
                                    Out
                                </a>

                               @*  <a asp-controller="InventoryTransactions"
                                   asp-action="ProductHistory"
                                   asp-route-id="@item.Id"
                                   class="btn btn-secondary btn-sm">
                                    History
                                </a> *@

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>